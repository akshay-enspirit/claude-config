{
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr view*)",
      "Bash(tsc*)",
      "Bash(npm run *)",
      "Bash(npx tsc*)",
      "Bash(find *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Date: %s\"}}' \"$(date +%Y-%m-%d)\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
